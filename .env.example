# =============================================
#  CampusEats — Environment Variables
#  Copy this file to .env and fill in values
# =============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — change this to a long random string in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production

# JWT expiry
JWT_EXPIRES_IN=24h

# Database path (relative to server/)
DB_PATH=./campuseats.db

# Canteen Settings — update these!
COLLEGE_NAME=Your College Name
CANTEEN_NAME=CampusEats
PICKUP_COUNTER=Counter 2, Ground Floor
TAX_RATE=0.05

# Admin / Staff default password (used during seed)
STAFF_DEFAULT_PASSWORD=staff@123
